# ──────────────────────────────────────────────────────────────
#  AIML SYMPO 2026 – Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Google Apps Script Web App URL
# Deploy your Apps Script as "Execute as: Me", Access: "Anyone"
# then paste the /exec URL here.
# NOTE: This must be an Apps Script /exec URL, not the Google Sheet edit URL.
APPS_SCRIPT_URL=https://script.google.com/macros/s/<SCRIPT_ID>/exec

# Registration fee per participant (default: 100)
PAYMENT_PER_HEAD=100

# JWT secret (used for any future token-based auth)
JWT_SECRET=replace_with_a_long_random_string

# Server port (optional, defaults to 5000)
PORT=5000
